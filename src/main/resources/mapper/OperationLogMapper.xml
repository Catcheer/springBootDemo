<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.springbootdemo.mapper.OperationLogMapper">

    <sql id="BaseWhere">
        <where>
            <if test="query.username != null and query.username != ''">
                AND username LIKE CONCAT('%', #{query.username}, '%')
            </if>
            <if test="query.module != null and query.module != ''">
                AND module = #{query.module}
            </if>
            <if test="query.operation != null and query.operation != ''">
                AND operation = #{query.operation}
            </if>
            <if test="query.createTime != null and query.createTime.size() == 2">
                AND create_time BETWEEN #{query.createTime[0]} AND #{query.createTime[1]}
            </if>
            <if test="query.status != null">
                AND status = #{query.status}
            </if>
        </where>
    </sql>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO operation_log (
            username, module, operation, request_method, request_uri,
            params, result, status, execution_time
        ) VALUES (
            #{username}, #{module}, #{operation}, #{requestMethod}, #{requestUri},
            #{params}, #{result}, #{status}, #{executionTime}
        )
    </insert>

    <select id="findByCondition" resultType="com.example.springbootdemo.model.OperationLog">
        SELECT id,
               username,
               module,
               operation,
               request_method AS requestMethod,
               request_uri AS requestUri,
               params,
               result,
               status,
               execution_time AS executionTime,
               create_time AS createTime
        FROM operation_log
        <include refid="BaseWhere"/>
        ORDER BY create_time DESC, id DESC
        LIMIT #{pageSize} OFFSET #{offset}
    </select>

    <select id="countByCondition" resultType="long">
        SELECT COUNT(*)
        FROM operation_log
        <include refid="BaseWhere"/>
    </select>

</mapper>
